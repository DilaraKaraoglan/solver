              "$ref": "#/components/schemas/PalletRoute"
            },
            "nullable": true
          },
          "assignment": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int32"
              }
            },
            "nullable": true
          },
